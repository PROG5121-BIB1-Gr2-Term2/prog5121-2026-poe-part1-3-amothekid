   public static  boolean checkerUserName (String username ){
     
     
      boolean hasUnderscore = false;
        boolean hasOtherChar = false;

        // Constraint username length must be equals to 5 and has an underscore
        if (username.length() <= 5) {
            for (int i = 0; i < username.length(); i++) {
                char c = username.charAt(i);
                if (c == '_') {
                    hasUnderscore = true;
                } else {
                    hasOtherChar = true;
                }
         if (hasUnderscore && hasOtherChar) {
                    return true;
                }
            }
        }
        return false;
     
    }
   public static boolean checkPasswordComplexity (String password ){
       
           boolean hasUppercase = false;
    boolean hasDigit = false;
    boolean hasSpecialChar = false;
    int minlength = 8;

    // i goes through each character and makes sure they have an unppercace or a digit
    for (int i = 0; i < password.length(); i++) {
        char c = password.charAt(i);

        if (Character.isUpperCase(c)) {
            hasUppercase = true;
        } else if (Character.isDigit(c)) {
            hasDigit = true;
        } else if (!Character.isLetterOrDigit(c)) {
            hasSpecialChar = true;
        }
    }

    // Final condition check
    return password.length() >= minlength && hasUppercase && hasDigit && hasSpecialChar;
}
   
   
